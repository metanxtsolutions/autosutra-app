# Google Analytics 4 measurement ID (Admin > Data Streams > your web stream)
# Optional. The real ID is baked in as a default in src/lib/analytics.ts
# since it isn't a secret. Only set this to override it, e.g. for a
# preview deploy pointed at a different GA4 property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification code (Settings > Ownership verification > HTML tag method)
# Only needed if you verify via the HTML tag method instead of DNS.
# Paste just the content value from the meta tag, not the whole tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Resend API key (resend.com > API Keys). Required for the Contact and
# Book a Demo forms to actually email leads to info@autosutra.in. Without
# this set, submissions are only logged server-side and no one receives
# them. This is a real secret: set it in Vercel's Environment Variables
# dashboard (Project > Settings > Environment Variables), never commit it.
RESEND_API_KEY=

# Optional. Sender address for lead emails, e.g. "AutoSutra <leads@autosutra.in>".
# Requires verifying autosutra.in as a sending domain in Resend first.
# Until then, leave unset to use Resend's shared onboarding@resend.dev sender.
RESEND_FROM_EMAIL=
