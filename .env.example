# Google Analytics 4 measurement ID (Admin > Data Streams > your web stream)
# Analytics won't load at all until this is set — safe to leave blank locally.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification code (Settings > Ownership verification > HTML tag method)
# Only paste the content value from the meta tag, not the whole tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
